# ──────────────────────────────────────────────
# Ciel Natal — Environment Variables
# Copy to .env.local and fill in your values
# ──────────────────────────────────────────────

# ── Supabase (https://supabase.com/dashboard) ──
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Project Settings > API > service_role (secret — never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Stripe (https://dashboard.stripe.com/apikeys) ──
STRIPE_SECRET_KEY=sk_live_...
# Stripe > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Upstash Redis (https://console.upstash.com) ──
# Database > REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── AI APIs ──
# Anthropic (https://console.anthropic.com) — for AI chat
ANTHROPIC_API_KEY=sk-ant-api03-...
# OpenAI (https://platform.openai.com/api-keys) — for TTS audio narration
OPENAI_API_KEY=sk-...

# ── Resend (https://resend.com/api-keys) — for transactional emails (welcome) ──
# Optional — without it, welcome emails are silently skipped
RESEND_API_KEY=re_...
# Verified sender (use onboarding@resend.dev for testing, domain-verified for prod)
RESEND_FROM=Ciel Natal <hello@yourdomain.com>

# ── Sentry (https://sentry.io) — error & performance monitoring ──
# Optional — without DSN, Sentry is a silent no-op.
# Project Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXX.ingest.sentry.io/XXX
# Same value as NEXT_PUBLIC_SENTRY_DSN (server-only fallback)
SENTRY_DSN=https://xxxxx@oXXX.ingest.sentry.io/XXX
# Account Settings > Auth Tokens — needed only for source map upload in CI
SENTRY_AUTH_TOKEN=sntrys_...
